PORT=3000
NODE_ENV=development

# NeonDB (PostgreSQL)
# Get your connection string from: https://console.neon.tech
DATABASE_URL=postgresql://<user>:<password>@<host>/<dbname>?sslmode=require

# JWT
JWT_SECRET=altera_jwt_super_secret_change_in_production
JWT_REFRESH_SECRET=altera_refresh_super_secret_change_in_production
JWT_EXPIRES_IN=60m
JWT_REFRESH_EXPIRES_IN=7d

# Blockchain (Polygon Amoy Testnet)
POLYGON_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
AIT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# IPFS
WEB3_STORAGE_TOKEN=your_web3_storage_token

# Redis
REDIS_URL=redis://localhost:6379

# Auth0
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_AUDIENCE=

# AI Providers
GROQ_API_KEY=your_groq_api_key
GROQ_MODELS=deepseek-r1-distill-qwen-32b,llama-3.3-70b-versatile,llama-3.1-8b-instant,mixtral-8x7b-32768
DEEPSEEK_API_KEY=your_deepseek_api_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODELS=gemini-1.5-flash,gemini-pro

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=altera
REQUIRE_CLOUDINARY_STORAGE=false

# CORS
ALLOWED_ORIGINS=http://localhost:3001,http://10.0.2.2:3000
